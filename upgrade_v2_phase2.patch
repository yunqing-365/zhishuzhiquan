+                    FROM valuations
+                    ORDER BY dynamic_price DESC LIMIT ?
+                    """,
+                    (limit,),
+                ).fetchall()
+            conn.close()
+        return [dict(r) for r in rows]
+    except Exception as e:
+        print(f"!! [storage] get_top_assets 失败: {e}")
+        return []
