# .env.example — 环境变量模板
# 复制为 .env 后按需修改：cp .env.example .env
#
# docker-compose 会自动读取同目录下的 .env 文件

# ── 前端端口（宿主机暴露端口）─────────────────────────────────────────
# 默认 80，如果宿主机 80 端口被占用可改为 8080
FRONTEND_PORT=80

# ── API Key 鉴权（可选）──────────────────────────────────────────────
# 留空则关闭鉴权（开发环境推荐）
# 非空时所有 /api/ 请求必须携带 Authorization: Bearer <API_KEY>
API_KEY=
