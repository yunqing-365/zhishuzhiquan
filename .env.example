# ────────────────────────────────────────────────────────
# AI-Echo 环境变量模板
# 使用方法：复制本文件为 .env，填入真实值后启动项目
# cp .env.example .env
# ────────────────────────────────────────────────────────

# ── 前端 (Vite) ──────────────────────────────────────────
# 后端 API 地址，开发时通常是本机，部署时改为服务器地址
VITE_API_URL=http://localhost:8000

# 项目展示名称（可选）
VITE_APP_NAME=指数之源 AI-Echo

# ── 后端 (FastAPI) ────────────────────────────────────────
# 服务监听配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 允许跨域的前端地址（生产环境必须填具体域名，不要用 *）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# HuggingFace 镜像（国内环境需要，下载 sentence-transformers 模型用）
HF_ENDPOINT=https://hf-mirror.com

# ── 可选：未来接入真实 AI 推理时填入 ─────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# CLIP_MODEL_PATH=./models/clip-vit-base-patch32

# ── 阶段 3：Web3 / 合约 ──────────────────────────────────────────
# WalletConnect Cloud 项目 ID（免费申请 https://cloud.walletconnect.com）
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# 目标链 ID（11155111 = Sepolia 测试网，1 = 主网）
VITE_CHAIN_ID=11155111

# 已部署的合约地址（npx hardhat run scripts/deploy.js --network sepolia 后填入）
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
SEPOLIA_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# 部署账户私钥（不要 0x 前缀，绝对不能提交到 git！）
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Alchemy / Infura Sepolia RPC URL
# 免费申请：https://dashboard.alchemy.com
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Etherscan API Key（合约验证用，可选）
# 申请：https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_key_here

# 收取手续费的地址（默认为部署者）
PLATFORM_ADMIN_ADDRESS=
ECOSYSTEM_FUND_ADDRESS=
