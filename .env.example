# .env.example — 知数知圈 (ZhiShuZhiQuan) 环境变量模板
# 复制为 .env 后按需修改：cp .env.example .env
# docker-compose 和 uvicorn 会自动读取同目录下的 .env 文件

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【必填】LLM 推理配置
# 标注 (AutoAnnotator) + 质检 (QualityScorer) + 安全审核 (ContentSafety) 均需要
# 不填时自动降级为规则模式（仍可运行，但标注质量下降）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 兼容 OpenAI 的第三方 LLM（如 DeepSeek、Moonshot、Azure OpenAI）
OPENAI_BASE_URL=https://api.openai.com/v1

# 主标注模型（推荐 gpt-4o-mini，性价比最优）
OPENAI_MODEL=gpt-4o-mini

# 质检副模型（多模型投票用，可填不同厂商模型以提升可信度）
# 留空时与主模型相同，仅通过 temperature 差异区分
OPENAI_MODEL_B=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【必填】JWT 认证密钥
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 生成强随机密钥：python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_in_production_use_random_hex_32

# JWT 签名算法（默认 HS256，生产可改为 RS256）
JWT_ALGORITHM=HS256

# Token 有效天数
JWT_EXPIRE_DAYS=30

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 服务配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 前端宿主机端口（Docker Compose 使用）
FRONTEND_PORT=80

# 跨域允许来源（逗号分隔，开发时可含 localhost:5173）
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:80

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 数据存储路径（相对于 ai-echo-backend/）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 主 SQLite（样本 + 包元数据 + 版本快照）
SQLITE_DB_PATH=data/zszq.db

# 创作者账本 SQLite（独立文件，避免事务争用）
CREATOR_LEDGER_DB_PATH=data/creator_ledger.db

# 旧版 JSON 账本路径（仅供首次启动时自动迁移，迁移后可留空）
CREATOR_LEDGER_JSON_PATH=data/creator_ledger.json

# 数据集输出根目录
DATASET_OUTPUT_DIR=data/datasets

# 流水线断点状态目录
PIPELINE_STATE_DIR=data/pipeline_state

# ChromaDB 向量库目录（语义去重用）
CHROMA_DB_DIR=data/chroma_db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 业务参数
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PLATFORM_REVENUE_RATIO=0.30
CREATOR_REVENUE_RATIO=0.70

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 可选：内容安全 LLM 审核（默认关闭，开启会增加延迟和费用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ENABLE_LLM_SAFETY=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 可选：B2B API Key 鉴权（留空则关闭）
# 非空时 /api/batch_valuate 等 B 端接口需携带 Authorization: Bearer <API_KEY>
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 可选：前端 API 地址（生产环境填实际域名）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
VITE_API_URL=http://localhost:8000
