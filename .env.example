# .env.example — 知数知圈 (ZhiShuZhiQuan) 环境变量模板
# 复制为 .env 后按需修改：cp .env.example .env
# docker-compose 和 uvicorn 会自动读取同目录下的 .env 文件

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【必填】LLM 推理配置
# 标注 (AutoAnnotator) + 质检 (QualityScorer) + 安全审核 (ContentSafety) 均需要
# 不填时自动降级为规则模式（仍可运行，但标注质量下降）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 兼容 OpenAI 的第三方 LLM（如 DeepSeek、Moonshot、Azure OpenAI）
# 默认使用 OpenAI 官方接口
OPENAI_BASE_URL=https://api.openai.com/v1

# 主标注模型（推荐 gpt-4o-mini，性价比最优）
OPENAI_MODEL=gpt-4o-mini

# 质检副模型（用于双模型投票，可与主模型相同）
OPENAI_MODEL_B=gpt-4o-mini

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 服务配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 前端宿主机端口（Docker Compose 使用）
FRONTEND_PORT=80

# 跨域允许来源（开发时可设为 *）
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:80

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 创作者账本 & JWT 认证
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT 签名密钥（生产环境请改为随机长字符串）
# 生成命令：python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_in_production_use_random_hex_32

# Token 有效期（小时）
JWT_EXPIRE_HOURS=72

# 创作者账本 SQLite 路径（相对于 ai-echo-backend/）
CREATOR_LEDGER_PATH=data/creator_ledger.db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 数据存储路径
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 数据集输出根目录
DATASET_OUTPUT_DIR=data/datasets

# ChromaDB 向量库路径（语义去重用）
CHROMA_DIR=data/chromadb

# 主 SQLite（估值历史 + 样本 + 版本快照）
SQLITE_DB_PATH=data/ai_echo.db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 可选：API Key 鉴权（留空则关闭）
# 非空时所有 /api/ 请求必须携带 Authorization: Bearer <API_KEY>
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 可选：ZK 证明（zkSNARK，不填则使用模拟哈希证明）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ZK_PROVER_URL=
ZK_VERIFY_KEY=
